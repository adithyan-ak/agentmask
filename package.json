  },
  "files": [
    "dist",
    "rules",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "minimatch": "^10.2.5",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.13"
